{
	"$schema": "mapex-device-simulator/v1",
	"name": "Dragino CS01-NB/NS",
	"protocolId": "mqtt",
	"enabled": true,
	"storeLogs": true,
	"config": {
		"kind": "mqtt",
		"brokerUrl": "",
		"clientId": "",
		"baseTopic": "dragino/cs01-nb-ns",
		"authMode": "none",
		"username": "",
		"password": "",
		"tlsCertPem": "",
		"tlsKeyPem": "",
		"tlsCaPem": "",
		"receiveEnabled": false,
		"subscriptions": []
	},
	"attributes": {
		"manufacturer": "Dragino",
		"model": "CS01-NB/NS"
	},
	"events": [
		{
			"id": "status",
			"name": "Device status",
			"mqtt": {
				"topic": "dragino/cs01-nb-ns/status",
				"qos": 0,
				"retain": false,
				"bodyMode": "raw",
				"bodyFields": [],
				"body": "{\"IMEI\":\"{{randInt(100000000000000,999999999999999)}}\",\"IMSI\":\"{{randInt(100000000000000,999999999999999)}}\",\"Model\":\"CS01-NB/NS\",\"fw_version\":\"1.0.0\",\"battery\":3.{{randInt(10,45)}},\"signal\":{{randInt(5,31)}},\"time\":\"2026/06/18 {{randInt(10,23)}}:{{randInt(10,59)}}:{{randInt(10,59)}}\"}"
			},
			"schedule": {
				"enabled": false,
				"every": 12,
				"unit": "hours"
			}
		},
		{
			"id": "uplink-current",
			"name": "4-channel current uplink",
			"mqtt": {
				"topic": "dragino/cs01-nb-ns/up",
				"qos": 0,
				"retain": false,
				"bodyMode": "raw",
				"bodyFields": [],
				"body": "{\"IMEI\": \"{{randInt(100000000000000,999999999999999)}}\", \"Model\": \"CS01-NB\", \"cur1\": \"{{randInt(0,30)}}\", \"cur2\": \"{{randInt(0,30)}}\", \"cur3\": \"{{randInt(0,30)}}\", \"cur4\": \"{{randInt(0,30)}}\", \"bat\": \"3.{{randInt(0,6)}}\"}"
			},
			"schedule": {
				"enabled": false,
				"every": 1,
				"unit": "hours"
			}
		}
	]
}
