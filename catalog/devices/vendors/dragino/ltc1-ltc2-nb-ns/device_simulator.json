{
	"$schema": "mapex-device-simulator/v1",
	"name": "Dragino LTC1/LTC2-NB/NS",
	"protocolId": "mqtt",
	"enabled": true,
	"storeLogs": true,
	"config": {
		"kind": "mqtt",
		"brokerUrl": "",
		"clientId": "",
		"baseTopic": "dragino/ltc1-ltc2-nb-ns",
		"authMode": "none",
		"username": "",
		"password": "",
		"tlsCertPem": "",
		"tlsKeyPem": "",
		"tlsCaPem": "",
		"receiveEnabled": false,
		"subscriptions": []
	},
	"attributes": {
		"manufacturer": "Dragino",
		"model": "LTC1/LTC2-NB/NS"
	},
	"events": [
		{
			"id": "status",
			"name": "Device status",
			"mqtt": {
				"topic": "dragino/ltc1-ltc2-nb-ns/status",
				"qos": 0,
				"retain": false,
				"bodyMode": "raw",
				"bodyFields": [],
				"body": "{\"IMEI\":\"{{randInt(100000000000000,999999999999999)}}\",\"IMSI\":\"{{randInt(100000000000000,999999999999999)}}\",\"Model\":\"LTC1/LTC2-NB/NS\",\"fw_version\":\"1.0.0\",\"battery\":3.{{randInt(10,45)}},\"signal\":{{randInt(5,31)}},\"time\":\"2026/06/18 {{randInt(10,23)}}:{{randInt(10,59)}}:{{randInt(10,59)}}\"}"
			},
			"schedule": {
				"enabled": false,
				"every": 12,
				"unit": "hours"
			}
		},
		{
			"id": "data",
			"name": "Sensor data uplink",
			"mqtt": {
				"topic": "dragino/ltc1-ltc2-nb-ns/up",
				"qos": 0,
				"retain": false,
				"bodyMode": "raw",
				"bodyFields": [],
				"body": "{\"IMEI\":\"{{randInt(100000000000000,999999999999999)}}\",\"IMSI\":\"{{randInt(100000000000000,999999999999999)}}\",\"Model\":\"LTC1/LTC2-NB/NS\",\"temp_alarm\":\"{{randInt(15,35)}}.{{randInt(0,9)}}\",\"channel1_temp\":{{randInt(15,35)}}.{{randInt(0,9)}},\"channel2_temp\":{{randInt(15,35)}}.{{randInt(0,9)}},\"battery\":3.{{randInt(10,45)}},\"signal\":{{randInt(5,31)}},\"time\":\"2026/06/18 {{randInt(10,23)}}:{{randInt(10,59)}}:{{randInt(10,59)}}\"}"
			},
			"schedule": {
				"enabled": false,
				"every": 1,
				"unit": "hours"
			}
		}
	]
}
