{
	"$schema": "mapex-device-simulator/v1",
	"name": "Dragino SE02-NB",
	"protocolId": "mqtt",
	"enabled": true,
	"storeLogs": true,
	"config": {
		"kind": "mqtt",
		"brokerUrl": "",
		"clientId": "",
		"baseTopic": "dragino/se02-nb",
		"authMode": "none",
		"username": "",
		"password": "",
		"tlsCertPem": "",
		"tlsKeyPem": "",
		"tlsCaPem": "",
		"receiveEnabled": false,
		"subscriptions": []
	},
	"attributes": {
		"manufacturer": "Dragino",
		"model": "SE02-NB"
	},
	"events": [
		{
			"id": "status",
			"name": "Device status",
			"mqtt": {
				"topic": "dragino/se02-nb/status",
				"qos": 0,
				"retain": false,
				"bodyMode": "raw",
				"bodyFields": [],
				"body": "{\"IMEI\":\"{{randInt(100000000000000,999999999999999)}}\",\"IMSI\":\"{{randInt(100000000000000,999999999999999)}}\",\"Model\":\"SE02-NB\",\"fw_version\":\"1.0.0\",\"battery\":3.{{randInt(10,45)}},\"signal\":{{randInt(5,31)}},\"time\":\"2026/06/18 {{randInt(10,23)}}:{{randInt(10,59)}}:{{randInt(10,59)}}\"}"
			},
			"schedule": {
				"enabled": false,
				"every": 12,
				"unit": "hours"
			}
		},
		{
			"id": "data",
			"name": "Sensor data uplink",
			"mqtt": {
				"topic": "dragino/se02-nb/up",
				"qos": 0,
				"retain": false,
				"bodyMode": "raw",
				"bodyFields": [],
				"body": "{\"IMEI\":\"{{randInt(100000000000000,999999999999999)}}\",\"IMSI\":\"{{randInt(100000000000000,999999999999999)}}\",\"Model\":\"SE02-NB\",\"tem\":{{randInt(0,100)}},\"hum\":{{randInt(30,90)}},\"ec\":{{randInt(100,2000)}},\"tem2\":{{randInt(0,100)}},\"hum2\":{{randInt(30,90)}},\"ec2\":{{randInt(0,100)}},\"interrupt\":{{randInt(0,1)}},\"interrupt_level\":{{randInt(0,1)}},\"battery\":3.{{randInt(10,45)}},\"signal\":{{randInt(5,31)}},\"time\":\"2026/06/18 {{randInt(10,23)}}:{{randInt(10,59)}}:{{randInt(10,59)}}\"}"
			},
			"schedule": {
				"enabled": false,
				"every": 1,
				"unit": "hours"
			}
		}
	]
}
