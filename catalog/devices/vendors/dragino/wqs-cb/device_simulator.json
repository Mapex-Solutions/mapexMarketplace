				"topic": "dragino/wqs-cb/status",
				"qos": 0,
				"retain": false,
				"bodyMode": "raw",
				"bodyFields": [],
				"body": "{\"IMEI\":\"{{randInt(100000000000000,999999999999999)}}\",\"IMSI\":\"{{randInt(100000000000000,999999999999999)}}\",\"Model\":\"WQS-CB/CS\",\"fw_version\":\"1.0.0\",\"battery\":3.{{randInt(10,45)}},\"signal\":{{randInt(5,31)}},\"time\":\"2026/06/18 {{randInt(10,23)}}:{{randInt(10,59)}}:{{randInt(10,59)}}\"}"
			},
			"schedule": {
				"enabled": false,
				"every": 12,
				"unit": "hours"
			}
		},
		{
			"id": "data",
			"name": "Sensor data uplink",
			"mqtt": {
				"topic": "dragino/wqs-cb/up",
				"qos": 0,
				"retain": false,
				"bodyMode": "raw",
