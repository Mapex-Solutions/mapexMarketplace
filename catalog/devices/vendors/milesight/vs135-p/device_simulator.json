			{
				"key": "Content-Type",
				"value": "application/json"
			}
		],
		"authMode": "none",
		"apiKeyHeader": "",
		"apiKey": "",
		"basicUser": "",
		"basicPass": ""
	},
	"attributes": {
		"manufacturer": "Milesight",
		"model": "VS135-P"
