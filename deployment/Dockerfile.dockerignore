# Keep it lean: the 591 MB catalog is mounted at runtime, not built in.
**/.git
**/.github
**/.claude
**/node_modules
mapexMarketplace/catalog
mapexMarketplace/data
mapexMarketplace/bin
mapexMarketplace/images
mapexMarketplace/INTERNALS
mapexMarketplace/deployment
mapexGoKit/bin
mapexGoKit/INTERNALS
